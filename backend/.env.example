# ==========================================
# AtomStudy Backend — Environment Variables
# ==========================================
# Copy this file to .dev.vars for local development.
# For production, use: wrangler secret put <KEY>
# ==========================================

# --- Required ---

# Google Gemini API Key
# Get one: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# Admin secret for dashboard authentication
# Use a strong, unique string in production
ADMIN_SECRET="your-strong-admin-secret"

# Firebase Web API Key
# Found in: Firebase Console > Project Settings > Web API Key
FIREBASE_API_KEY="your-firebase-web-api-key"

# Firebase Admin Service Account (base64 encoded)
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Generate new private key
# 3. base64 -w0 path/to/service-account.json
FIREBASE_SERVICE_ACCOUNT="base64-encoded-service-account-json"

# --- Optional ---

# YouTube Data API Key (for video recommendations)
YOUTUBE_API_KEY="your-youtube-api-key"
